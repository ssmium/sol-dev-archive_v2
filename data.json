      "fileName": "dev-archive.html",
      "fileContent": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>SOL.DEV — 개발 아카이브</title>\n<link href=\"https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Instrument+Serif:ital@0;1&family=Pretendard:wght@300;400;500;600&display=swap\" rel=\"stylesheet\">\n<style>\n  :root {\n    --bg: #0e0e10;\n    --surface: #18181c;\n    --surface2: #22222a;\n    --border: #2e2e38;\n    --accent: #c8f04e;\n    --accent2: #7c6af7;\n    --text: #e8e8f0;\n    --text2: #8888a0;\n    --text3: #55556a;\n    --red: #f07070;\n    --yellow: #f0c060;\n    --green: #70d0a0;\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    background: var(--bg);\n    color: var(--text);\n    font-family: 'Pretendard', sans-serif;\n    font-size: 14px;\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n  }\n\n  /* HEADER */\n  header {\n    border-bottom: 1px solid var(--border);\n    padding: 16px 32px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    position: sticky;\n    top: 0;\n    background: var(--bg);\n    z-index: 100;\n  }\n  .logo {\n    font-family: 'DM Mono', monospace;\n    font-size: 15px;\n    color: var(--accent);\n    letter-spacing: 0.05em;\n  }\n  .logo span { color: var(--text3); }\n  header nav {\n    display: flex;\n    gap: 4px;\n  }\n  .nav-btn {\n    background: none;\n    border: 1px solid transparent;\n    color: var(--text2);\n    font-family: 'DM Mono', monospace;\n    font-size: 12px;\n    padding: 6px 14px;\n    border-radius: 6px;\n    cursor: pointer;\n    transition: all .15s;\n  }\n  .nav-btn:hover { border-color: var(--border); color: var(--text); }\n  .nav-btn.active { background: var(--surface2); border-color: var(--border); color: var(--accent); }\n\n  /* LAYOUT */\n  .layout {\n    display: flex;\n    flex: 1;\n    min-height: 0;\n  }\n\n  /* SIDEBAR */\n  aside {\n    width: 260px;\n    min-width: 260px;\n    border-right: 1px solid var(--border);\n    display: flex;\n    flex-direction: column;\n    background: var(--surface);\n  }\n  .sidebar-header {\n    padding: 20px 20px 12px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n  }\n  .sidebar-title {\n    font-family: 'DM Mono', monospace;\n    font-size: 11px;\n    color: var(--text3);\n    text-transform: uppercase;\n    letter-spacing: 0.12em;\n  }\n  .icon-btn {\n    width: 28px; height: 28px;\n    background: none;\n    border: 1px solid var(--border);\n    border-radius: 6px;\n    color: var(--text2);\n    cursor: pointer;\n    font-size: 16px;\n    display: flex; align-items: center; justify-content: center;\n    transition: all .15s;\n  }\n  .icon-btn:hover { background: var(--surface2); color: var(--text); }\n\n  .project-list { flex: 1; overflow-y: auto; padding: 0 8px 16px; }\n  .project-item {\n    padding: 10px 12px;\n    border-radius: 8px;\n    cursor: pointer;\n    transition: all .15s;\n    margin-bottom: 2px;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n  .project-item:hover { background: var(--surface2); }\n  .project-item.active { background: var(--surface2); }\n  .project-dot {\n    width: 8px; height: 8px;\n    border-radius: 50%;\n    flex-shrink: 0;\n  }\n  .project-info { flex: 1; min-width: 0; }\n  .project-name {\n    font-size: 13px;\n    font-weight: 500;\n    color: var(--text);\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n  }\n  .project-item.active .project-name { color: var(--accent); }\n  .project-meta {\n    font-family: 'DM Mono', monospace;\n    font-size: 11px;\n    color: var(--text3);\n    margin-top: 2px;\n  }\n\n  /* MAIN */\n  main { flex: 1; overflow-y: auto; padding: 32px 40px; }\n\n  /* EMPTY STATE */\n  .empty-state {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    height: 60vh;\n    gap: 12px;\n  }\n  .empty-icon { font-size: 40px; opacity: .3; }\n  .empty-text { color: var(--text3); font-family: 'DM Mono', monospace; font-size: 13px; }\n\n  /* PROJECT DETAIL */\n  .project-header {\n    display: flex;\n    align-items: flex-start;\n    justify-content: space-between;\n    margin-bottom: 32px;\n    padding-bottom: 24px;\n    border-bottom: 1px solid var(--border);\n  }\n  .project-title-area {}\n  .project-tag {\n    font-family: 'DM Mono', monospace;\n    font-size: 11px;\n    color: var(--text3);\n    margin-bottom: 6px;\n  }\n  .project-title {\n    font-family: 'Instrument Serif', serif;\n    font-size: 28px;\n    color: var(--text);\n    font-style: italic;\n    line-height: 1.2;\n  }\n  .project-desc {\n    color: var(--text2);\n    font-size: 13px;\n    margin-top: 6px;\n    max-width: 500px;\n    line-height: 1.6;\n  }\n  .btn {\n    padding: 8px 18px;\n    border-radius: 8px;\n    border: none;\n    cursor: pointer;\n    font-family: 'Pretendard', sans-serif;\n    font-size: 13px;\n    font-weight: 500;\n    transition: all .15s;\n  }\n  .btn-primary {\n    background: var(--accent);\n    color: #0e0e10;\n  }\n  .btn-primary:hover { background: #d8ff5e; }\n  .btn-secondary {\n    background: var(--surface2);\n    color: var(--text2);\n    border: 1px solid var(--border);\n  }\n  .btn-secondary:hover { color: var(--text); border-color: var(--text3); }\n  .btn-danger {\n    background: none;\n    color: var(--red);\n    border: 1px solid transparent;\n    font-size: 12px;\n    padding: 6px 12px;\n  }\n  .btn-danger:hover { border-color: var(--red); background: rgba(240,112,112,.08); }\n\n  /* STATS */\n  .stats-row {\n    display: flex;\n    gap: 12px;\n    margin-bottom: 28px;\n  }\n  .stat-card {\n    background: var(--surface);\n    border: 1px solid var(--border);\n    border-radius: 10px;\n    padding: 14px 20px;\n    flex: 1;\n  }\n  .stat-label {\n    font-family: 'DM Mono', monospace;\n    font-size: 10px;\n    color: var(--text3);\n    text-transform: uppercase;\n    letter-spacing: .1em;\n    margin-bottom: 6px;\n  }\n  .stat-value {\n    font-family: 'DM Mono', monospace;\n    font-size: 22px;\n    font-weight: 500;\n    color: var(--text);\n  }\n  .stat-value span { color: var(--accent); }\n\n  /* VERSION SECTION HEADER */\n  .section-header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 16px;\n  }\n  .section-label {\n    font-family: 'DM Mono', monospace;\n    font-size: 11px;\n    color: var(--text3);\n    text-transform: uppercase;\n    letter-spacing: .12em;\n  }\n\n  /* VERSION TIMELINE */\n  .version-timeline { display: flex; flex-direction: column; gap: 2px; }\n\n  .version-card {\n    background: var(--surface);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    overflow: hidden;\n    transition: border-color .15s;\n  }\n  .version-card:hover { border-color: var(--text3); }\n  .version-card.expanded { border-color: var(--border); }\n\n  .version-card-head {\n    padding: 16px 20px;\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    cursor: pointer;\n    user-select: none;\n  }\n  .v-badge {\n    font-family: 'DM Mono', monospace;\n    font-size: 11px;\n    font-weight: 500;\n    padding: 3px 10px;\n    border-radius: 20px;\n    background: var(--surface2);\n    color: var(--accent);\n    border: 1px solid var(--border);\n    white-space: nowrap;\n  }\n  .v-summary { flex: 1; }\n  .v-title {\n    font-size: 14px;\n    font-weight: 500;\n    color: var(--text);\n    margin-bottom: 2px;\n  }\n  .v-date {\n    font-family: 'DM Mono', monospace;\n    font-size: 11px;\n    color: var(--text3);\n  }\n  .v-tags { display: flex; gap: 6px; align-items: center; }\n  .v-tag {\n    font-family: 'DM Mono', monospace;\n    font-size: 10px;\n    padding: 2px 8px;\n    border-radius: 4px;\n  }\n  .tag-fix { background: rgba(240,112,112,.15); color: var(--red); }\n  .tag-feat { background: rgba(124,106,247,.15); color: #a090ff; }\n  .tag-update { background: rgba(112,208,160,.15); color: var(--green); }\n  .tag-init { background: rgba(200,240,78,.1); color: var(--accent); }\n  .v-chevron {\n    color: var(--text3);\n    font-size: 12px;\n    transition: transform .2s;\n    font-family: 'DM Mono', monospace;\n  }\n  .version-card.expanded .v-chevron { transform: rotate(180deg); }\n\n  .version-card-body {\n    display: none;\n    padding: 0 20px 20px;\n    border-top: 1px solid var(--border);\n  }\n  .version-card.expanded .version-card-body { display: block; }\n\n  .v-section { margin-top: 16px; }\n  .v-section-label {\n    font-family: 'DM Mono', monospace;\n    font-size: 10px;\n    color: var(--text3);\n    text-transform: uppercase;\n    letter-spacing: .1em;\n    margin-bottom: 8px;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .v-section-label::before {\n    content: '';\n    display: inline-block;\n    width: 3px; height: 3px;\n    border-radius: 50%;\n    background: currentColor;\n  }\n  .v-content {\n    font-size: 13px;\n    color: var(--text2);\n    line-height: 1.7;\n    white-space: pre-wrap;\n    word-break: break-word;\n  }\n  .v-drive-link {\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    font-family: 'DM Mono', monospace;\n    font-size: 12px;\n    color: var(--accent2);\n    text-decoration: none;\n    padding: 6px 12px;\n    background: rgba(124,106,247,.1);\n    border-radius: 6px;\n    border: 1px solid rgba(124,106,247,.2);\n    transition: all .15s;\n    margin-top: 4px;\n  }\n  .v-drive-link:hover { background: rgba(124,106,247,.2); }\n\n  .v-actions {\n    display: flex;\n    gap: 8px;\n    margin-top: 16px;\n    padding-top: 12px;\n    border-top: 1px solid var(--border);\n    justify-content: flex-end;\n  }\n\n  /* MODAL */\n  .modal-overlay {\n    position: fixed;\n    inset: 0;\n    background: rgba(0,0,0,.7);\n    z-index: 200;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    backdrop-filter: blur(4px);\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity .2s;\n  }\n  .modal-overlay.open { opacity: 1; pointer-events: all; }\n\n  .modal {\n    background: var(--surface);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n    width: 560px;\n    max-width: 95vw;\n    max-height: 90vh;\n    overflow-y: auto;\n    transform: translateY(16px);\n    transition: transform .2s;\n  }\n  .modal-overlay.open .modal { transform: translateY(0); }\n\n  .modal-header {\n    padding: 24px 24px 0;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 20px;\n  }\n  .modal-title {\n    font-family: 'Instrument Serif', serif;\n    font-size: 22px;\n    color: var(--text);\n    font-style: italic;\n  }\n  .modal-close {\n    width: 32px; height: 32px;\n    background: var(--surface2);\n    border: 1px solid var(--border);\n    border-radius: 8px;\n    color: var(--text2);\n    cursor: pointer;\n    font-size: 18px;\n    display: flex; align-items: center; justify-content: center;\n    transition: all .15s;\n  }\n  .modal-close:hover { color: var(--text); }\n\n  .modal-body { padding: 0 24px 24px; }\n\n  .form-group { margin-bottom: 16px; }\n  .form-label {\n    display: block;\n    font-family: 'DM Mono', monospace;\n    font-size: 11px;\n    color: var(--text3);\n    text-transform: uppercase;\n    letter-spacing: .1em;\n    margin-bottom: 6px;\n  }\n  .form-input, .form-textarea, .form-select {\n    width: 100%;\n    background: var(--surface2);\n    border: 1px solid var(--border);\n    border-radius: 8px;\n    padding: 10px 14px;\n    color: var(--text);\n    font-family: 'Pretendard', sans-serif;\n    font-size: 13px;\n    transition: border-color .15s;\n    outline: none;\n    resize: none;\n  }\n  .form-input:focus, .form-textarea:focus, .form-select:focus {\n    border-color: var(--accent);\n  }\n  .form-textarea { min-height: 80px; line-height: 1.6; }\n  .form-select option { background: var(--surface2); }\n\n  .form-row { display: flex; gap: 12px; }\n  .form-row .form-group { flex: 1; }\n\n  .modal-footer {\n    display: flex;\n    justify-content: flex-end;\n    gap: 8px;\n    padding-top: 8px;\n  }\n\n  /* TAG SELECT */\n  .tag-options { display: flex; gap: 6px; flex-wrap: wrap; }\n  .tag-opt {\n    padding: 5px 12px;\n    border-radius: 6px;\n    border: 1px solid var(--border);\n    background: none;\n    cursor: pointer;\n    font-size: 12px;\n    font-family: 'DM Mono', monospace;\n    color: var(--text2);\n    transition: all .15s;\n  }\n  .tag-opt.selected-fix { background: rgba(240,112,112,.15); color: var(--red); border-color: var(--red); }\n  .tag-opt.selected-feat { background: rgba(124,106,247,.15); color: #a090ff; border-color: #a090ff; }\n  .tag-opt.selected-update { background: rgba(112,208,160,.15); color: var(--green); border-color: var(--green); }\n  .tag-opt.selected-init { background: rgba(200,240,78,.1); color: var(--accent); border-color: var(--accent); }\n  .tag-opt:not([class*=\"selected\"]):hover { border-color: var(--text3); color: var(--text); }\n\n  /* SCROLLBAR */\n  ::-webkit-scrollbar { width: 4px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }\n\n  /* COLOR OPTIONS */\n  .color-opts { display: flex; gap: 8px; }\n  .color-opt {\n    width: 24px; height: 24px;\n    border-radius: 50%;\n    border: 2px solid transparent;\n    cursor: pointer;\n    transition: transform .15s;\n  }\n  .color-opt:hover { transform: scale(1.2); }\n  .color-opt.selected { border-color: white; }\n\n  /* SEARCH */\n  .search-bar {\n    padding: 12px 8px;\n    border-bottom: 1px solid var(--border);\n  }\n  .search-input {\n    width: 100%;\n    background: var(--surface2);\n    border: 1px solid var(--border);\n    border-radius: 8px;\n    padding: 8px 12px;\n    color: var(--text);\n    font-family: 'DM Mono', monospace;\n    font-size: 12px;\n    outline: none;\n  }\n  .search-input::placeholder { color: var(--text3); }\n  .search-input:focus { border-color: var(--accent); }\n\n  /* FILE UPLOAD */\n  .file-upload-area {\n    border: 1px dashed var(--border);\n    border-radius: 8px;\n    padding: 14px;\n    text-align: center;\n    cursor: pointer;\n    font-family: 'DM Mono', monospace;\n    font-size: 12px;\n    color: var(--text3);\n    transition: all .15s;\n  }\n  .file-upload-area:hover { border-color: var(--accent); color: var(--accent); }\n  .file-upload-area.has-file { border-color: var(--green); color: var(--green); background: rgba(112,208,160,.05); }\n\n  .file-btns { display: flex; gap: 6px; margin-top: 4px; }\n  .btn-file {\n    display: inline-flex; align-items: center; gap: 5px;\n    font-family: 'DM Mono', monospace; font-size: 11px;\n    padding: 5px 12px; border-radius: 6px; cursor: pointer;\n    border: 1px solid var(--border); background: none;\n    color: var(--text2); transition: all .15s; text-decoration: none;\n  }\n  .btn-file:hover { border-color: var(--text3); color: var(--text); }\n  .btn-file.preview { border-color: var(--accent2); color: var(--accent2); background: rgba(124,106,247,.08); }\n  .btn-file.preview:hover { background: rgba(124,106,247,.15); }\n  .btn-file.download { border-color: var(--green); color: var(--green); background: rgba(112,208,160,.08); }\n  .btn-file.download:hover { background: rgba(112,208,160,.15); }\n\n  /* TOAST */\n  .toast {\n    position: fixed;\n    bottom: 24px;\n    right: 24px;\n    background: var(--surface2);\n    border: 1px solid var(--border);\n    border-radius: 10px;\n    padding: 12px 18px;\n    font-size: 13px;\n    color: var(--text);\n    z-index: 999;\n    transform: translateY(8px);\n    opacity: 0;\n    transition: all .2s;\n    pointer-events: none;\n  }\n  .toast.show { transform: translateY(0); opacity: 1; }\n  .toast.success { border-color: var(--green); }\n</style>\n</head>\n<body>\n\n<header>\n  <div class=\"logo\">SOL<span>.DEV</span> / archive</div>\n  <div style=\"display:flex;align-items:center;gap:12px;\">\n    <span id=\"sync-status\" style=\"font-family:'DM Mono',monospace;font-size:11px;color:var(--text3);display:flex;align-items:center;gap:5px;\"></span>\n    <nav>\n      <button class=\"nav-btn active\" id=\"nav-projects\" onclick=\"setView('projects')\">프로젝트</button>\n      <button class=\"nav-btn\" id=\"nav-all\" onclick=\"setView('all')\">전체 버전</button>\n      <button class=\"nav-btn\" onclick=\"openSettingsModal()\" title=\"GitHub 설정\">⚙</button>\n    </nav>\n  </div>\n</header>\n\n<div class=\"layout\">\n  <!-- SIDEBAR -->\n  <aside>\n    <div class=\"sidebar-header\">\n      <span class=\"sidebar-title\">Projects</span>\n      <button class=\"icon-btn\" onclick=\"openProjectModal()\" title=\"새 프로젝트\">+</button>\n    </div>\n    <div class=\"search-bar\">\n      <input class=\"search-input\" id=\"project-search\" placeholder=\"프로젝트 검색...\" oninput=\"renderSidebar()\">\n    </div>\n    <div class=\"project-list\" id=\"project-list\"></div>\n  </aside>\n\n  <!-- MAIN -->\n  <main id=\"main-area\">\n    <div class=\"empty-state\" id=\"empty-state\">\n      <div class=\"empty-icon\">◈</div>\n      <div class=\"empty-text\">프로젝트를 선택하거나 새로 만들어보세요</div>\n    </div>\n    <div id=\"project-detail\" style=\"display:none;\"></div>\n    <div id=\"all-versions\" style=\"display:none;\"></div>\n  </main>\n</div>\n\n<!-- PROJECT MODAL -->\n<div class=\"modal-overlay\" id=\"project-modal\">\n  <div class=\"modal\">\n    <div class=\"modal-header\">\n      <div class=\"modal-title\" id=\"project-modal-title\">새 프로젝트</div>\n      <button class=\"modal-close\" onclick=\"closeModal('project-modal')\">×</button>\n    </div>\n    <div class=\"modal-body\">\n      <input type=\"hidden\" id=\"pm-id\">\n      <div class=\"form-group\">\n        <label class=\"form-label\">프로젝트 이름</label>\n        <input class=\"form-input\" id=\"pm-name\" placeholder=\"예: SOLSIGNAL, wallet.html, 오늘서울어디갈까\">\n      </div>\n      <div class=\"form-group\">\n        <label class=\"form-label\">설명 (선택)</label>\n        <textarea class=\"form-textarea\" id=\"pm-desc\" placeholder=\"어떤 프로젝트인지 간단히...\" style=\"min-height:60px;\"></textarea>\n      </div>\n      <div class=\"form-group\">\n        <label class=\"form-label\">색상</label>\n        <div class=\"color-opts\" id=\"color-opts\">\n          <div class=\"color-opt selected\" data-color=\"#c8f04e\" style=\"background:#c8f04e;\" onclick=\"selectColor('#c8f04e')\"></div>\n          <div class=\"color-opt\" data-color=\"#7c6af7\" style=\"background:#7c6af7;\" onclick=\"selectColor('#7c6af7')\"></div>\n          <div class=\"color-opt\" data-color=\"#f07070\" style=\"background:#f07070;\" onclick=\"selectColor('#f07070')\"></div>\n          <div class=\"color-opt\" data-color=\"#f0c060\" style=\"background:#f0c060;\" onclick=\"selectColor('#f0c060')\"></div>\n          <div class=\"color-opt\" data-color=\"#70d0a0\" style=\"background:#70d0a0;\" onclick=\"selectColor('#70d0a0')\"></div>\n          <div class=\"color-opt\" data-color=\"#60b8f0\" style=\"background:#60b8f0;\" onclick=\"selectColor('#60b8f0')\"></div>\n          <div class=\"color-opt\" data-color=\"#f090d0\" style=\"background:#f090d0;\" onclick=\"selectColor('#f090d0')\"></div>\n        </div>\n      </div>\n      <div class=\"modal-footer\">\n        <button class=\"btn btn-secondary\" onclick=\"closeModal('project-modal')\">취소</button>\n        <button class=\"btn btn-primary\" onclick=\"saveProject()\">저장</button>\n      </div>\n    </div>\n  </div>\n</div>\n\n<!-- VERSION MODAL -->\n<div class=\"modal-overlay\" id=\"version-modal\">\n  <div class=\"modal\">\n    <div class=\"modal-header\">\n      <div class=\"modal-title\" id=\"version-modal-title\">버전 추가</div>\n      <button class=\"modal-close\" onclick=\"closeModal('version-modal')\">×</button>\n    </div>\n    <div class=\"modal-body\">\n      <input type=\"hidden\" id=\"vm-id\">\n      <input type=\"hidden\" id=\"vm-project-id\">\n      <div class=\"form-row\">\n        <div class=\"form-group\">\n          <label class=\"form-label\">버전 번호</label>\n          <input class=\"form-input\" id=\"vm-version\" placeholder=\"예: v1.0, v2.3\">\n        </div>\n        <div class=\"form-group\">\n          <label class=\"form-label\">날짜</label>\n          <input class=\"form-input\" id=\"vm-date\" type=\"date\">\n        </div>\n      </div>\n      <div class=\"form-group\">\n        <label class=\"form-label\">제목 / 한 줄 요약</label>\n        <input class=\"form-input\" id=\"vm-title\" placeholder=\"이 버전을 한 줄로 표현하면?\">\n      </div>\n      <div class=\"form-group\">\n        <label class=\"form-label\">태그</label>\n        <div class=\"tag-options\">\n          <button class=\"tag-opt\" data-tag=\"init\" onclick=\"toggleTag(this)\">🌱 init</button>\n          <button class=\"tag-opt\" data-tag=\"feat\" onclick=\"toggleTag(this)\">✨ feat</button>\n          <button class=\"tag-opt\" data-tag=\"fix\" onclick=\"toggleTag(this)\">🔧 fix</button>\n          <button class=\"tag-opt\" data-tag=\"update\" onclick=\"toggleTag(this)\">🔄 update</button>\n        </div>\n      </div>\n      <div class=\"form-group\">\n        <label class=\"form-label\">무엇을 바꿨나요?</label>\n        <textarea class=\"form-textarea\" id=\"vm-changes\" placeholder=\"변경 내용을 적어주세요\"></textarea>\n      </div>\n      <div class=\"form-group\">\n        <label class=\"form-label\">왜 바꿨나요?</label>\n        <textarea class=\"form-textarea\" id=\"vm-reason\" placeholder=\"업데이트 이유나 배경을 적어주세요\"></textarea>\n      </div>\n      <div class=\"form-group\">\n        <label class=\"form-label\">발생한 오류 (선택)</label>\n        <textarea class=\"form-textarea\" id=\"vm-error\" placeholder=\"어떤 버그나 오류가 있었나요?\"></textarea>\n      </div>\n      <div class=\"form-group\">\n        <label class=\"form-label\">HTML 파일 첨부 (선택)</label>\n        <div class=\"file-upload-area\" id=\"file-upload-area\" onclick=\"document.getElementById('vm-file-input').click()\">\n          <div id=\"file-upload-label\">📎 클릭해서 HTML 파일 선택</div>\n        </div>\n        <input type=\"file\" id=\"vm-file-input\" accept=\".html\" style=\"display:none;\" onchange=\"handleFileUpload(this)\">\n        <input type=\"hidden\" id=\"vm-file-name\">\n        <input type=\"hidden\" id=\"vm-file-content\">\n      </div>\n      <div class=\"modal-footer\">\n        <button class=\"btn btn-secondary\" onclick=\"closeModal('version-modal')\">취소</button>\n        <button class=\"btn btn-primary\" onclick=\"saveVersion()\">저장</button>\n      </div>\n    </div>\n  </div>\n</div>\n\n<!-- GITHUB SETTINGS MODAL -->\n<div class=\"modal-overlay\" id=\"settings-modal\">\n  <div class=\"modal\" style=\"max-width:480px;\">\n    <div class=\"modal-header\">\n      <div class=\"modal-title\">GitHub 연동 설정</div>\n      <button class=\"modal-close\" onclick=\"closeModal('settings-modal')\">×</button>\n    </div>\n    <div class=\"modal-body\">\n      <div style=\"background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px 16px;margin-bottom:20px;font-family:'DM Mono',monospace;font-size:12px;color:var(--text2);line-height:1.7;\">\n        📋 <strong style=\"color:var(--text);\">설정 방법</strong><br>\n        1. GitHub에서 <strong>private repo</strong> 생성 (예: sol-dev-archive)<br>\n        2. Settings → Developer settings → <strong>Personal access tokens</strong><br>\n        3. <strong>Fine-grained token</strong> 생성 → repo 권한: Contents <strong>Read & Write</strong><br>\n        4. 아래에 입력 후 저장\n      </div>\n      <div class=\"form-group\">\n        <label class=\"form-label\">GitHub 사용자명 (owner)</label>\n        <input class=\"form-input\" id=\"s-owner\" placeholder=\"예: solkim\">\n      </div>\n      <div class=\"form-group\">\n        <label class=\"form-label\">레포지토리 이름</label>\n        <input class=\"form-input\" id=\"s-repo\" placeholder=\"예: sol-dev-archive\">\n      </div>\n      <div class=\"form-group\">\n        <label class=\"form-label\">Personal Access Token</label>\n        <input class=\"form-input\" id=\"s-token\" type=\"password\" placeholder=\"github_pat_...\">\n        <div style=\"font-family:'DM Mono',monospace;font-size:11px;color:var(--text3);margin-top:5px;\">토큰은 이 브라우저 로컬에만 저장됩니다</div>\n      </div>\n      <div class=\"modal-footer\" style=\"gap:8px;\">\n        <button class=\"btn btn-secondary\" onclick=\"clearGHConfig()\">연동 해제</button>\n        <button class=\"btn btn-secondary\" onclick=\"closeModal('settings-modal')\">취소</button>\n        <button class=\"btn btn-primary\" onclick=\"saveGHConfig()\">저장 & 연동</button>\n      </div>\n    </div>\n  </div>\n</div>\n\n<div class=\"toast\" id=\"toast\"></div>\n\n<script>\n// ─── STATE ───────────────────────────────────────────────────\nlet state = {\n  projects: [],\n  versions: [],\n  selectedProject: null,\n  currentView: 'projects',\n  editingProjectId: null,\n  editingVersionId: null,\n  selectedColor: '#c8f04e',\n  selectedTags: []\n};\n\n// ─── GITHUB CONFIG ───────────────────────────────────────────\nfunction getGHConfig() {\n  return {\n    token: localStorage.getItem('gh-token') || '',\n    owner: localStorage.getItem('gh-owner') || '',\n    repo:  localStorage.getItem('gh-repo')  || '',\n  };\n}\nfunction isGHConfigured() {\n  const c = getGHConfig();\n  return c.token && c.owner && c.repo;\n}\nfunction ghHeaders() {\n  return {\n    'Authorization': `Bearer ${getGHConfig().token}`,\n    'Content-Type': 'application/json',\n    'X-GitHub-Api-Version': '2022-11-28'\n  };\n}\nfunction ghUrl() {\n  const { owner, repo } = getGHConfig();\n  return `https://api.github.com/repos/${owner}/${repo}/contents/data.json`;\n}\n\n// ─── PERSISTENCE ─────────────────────────────────────────────\nlet _sha = null; // 현재 data.json의 SHA (업데이트 시 필요)\n\nfunction setSyncStatus(status) {\n  // status: 'idle' | 'syncing' | 'ok' | 'error' | 'local'\n  const el = document.getElementById('sync-status');\n  if (!el) return;\n  const map = {\n    idle:    { icon: '○', color: 'var(--text3)',  label: '' },\n    syncing: { icon: '◌', color: 'var(--yellow)', label: '동기화 중...' },\n    ok:      { icon: '●', color: 'var(--green)',  label: 'GitHub 연동됨' },\n    error:   { icon: '●', color: 'var(--red)',    label: '동기화 실패' },\n    local:   { icon: '●', color: 'var(--text3)',  label: '로컬 저장' },\n  };\n  const s = map[status] || map.idle;\n  el.innerHTML = `<span style=\"color:${s.color};font-size:9px;\">${s.icon}</span> ${s.label}`;\n}\n\nasync function save() {\n  const data = { projects: state.projects, versions: state.versions };\n  // 항상 로컬에도 저장 (오프라인 대비)\n  localStorage.setItem('sol-dev-archive', JSON.stringify(data));\n\n  if (!isGHConfigured()) { setSyncStatus('local'); return; }\n\n  setSyncStatus('syncing');\n  try {\n    const content = btoa(unescape(encodeURIComponent(JSON.stringify(data, null, 2))));\n    const body = { message: 'update archive data', content };\n    if (_sha) body.sha = _sha;\n\n    const res = await fetch(ghUrl(), {\n      method: 'PUT',\n      headers: ghHeaders(),\n      body: JSON.stringify(body)\n    });\n    if (!res.ok) throw new Error(await res.text());\n    const json = await res.json();\n    _sha = json.content.sha;\n    setSyncStatus('ok');\n  } catch(e) {\n    console.error(e);\n    setSyncStatus('error');\n    toast('GitHub 저장 실패 — 로컬에만 저장됨', '');\n  }\n}\n\nasync function load() {\n  // 로컬 캐시 먼저 (빠른 초기 렌더)\n  const local = localStorage.getItem('sol-dev-archive');\n  if (local) {\n    const parsed = JSON.parse(local);\n    state.projects = parsed.projects || [];\n    state.versions = parsed.versions || [];\n  }\n\n  if (!isGHConfigured()) { setSyncStatus('local'); return; }\n\n  setSyncStatus('syncing');\n  try {\n    const res = await fetch(ghUrl(), { headers: ghHeaders() });\n    if (res.status === 404) {\n      // 파일 없음 = 첫 접속, 현재 데이터로 초기 커밋\n      _sha = null;\n      setSyncStatus('ok');\n      await save();\n      return;\n    }\n    if (!res.ok) throw new Error();\n    const json = await res.json();\n    _sha = json.sha;\n    const decoded = decodeURIComponent(escape(atob(json.content.replace(/\\n/g,''))));\n    const parsed = JSON.parse(decoded);\n    state.projects = parsed.projects || [];\n    state.versions = parsed.versions || [];\n    localStorage.setItem('sol-dev-archive', JSON.stringify(parsed));\n    setSyncStatus('ok');\n    renderSidebar();\n    renderMain();\n  } catch(e) {\n    console.error(e);\n    setSyncStatus('error');\n  }\n}\n\n// ─── UTILS ───────────────────────────────────────────────────\nfunction uid() { return Date.now().toString(36) + Math.random().toString(36).slice(2,7); }\nfunction today() { return new Date().toISOString().slice(0,10); }\nfunction formatDate(d) {\n  if (!d) return '';\n  const [y,m,day] = d.split('-');\n  return `${y}.${m}.${day}`;\n}\nfunction toast(msg, type='') {\n  const el = document.getElementById('toast');\n  el.textContent = msg;\n  el.className = 'toast show ' + type;\n  setTimeout(() => el.className = 'toast', 2000);\n}\n\n// ─── VIEW ────────────────────────────────────────────────────\nfunction setView(v) {\n  state.currentView = v;\n  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));\n  document.getElementById('nav-' + v).classList.add('active');\n  renderMain();\n}\n\n// ─── RENDER SIDEBAR ──────────────────────────────────────────\nfunction renderSidebar() {\n  const q = document.getElementById('project-search').value.toLowerCase();\n  const list = document.getElementById('project-list');\n  const filtered = state.projects.filter(p => p.name.toLowerCase().includes(q));\n\n  if (filtered.length === 0) {\n    list.innerHTML = `<div style=\"padding:16px 12px; color:var(--text3); font-family:'DM Mono',monospace; font-size:12px;\">프로젝트 없음</div>`;\n    return;\n  }\n\n  list.innerHTML = filtered.map(p => {\n    const vCount = state.versions.filter(v => v.projectId === p.id).length;\n    const latest = state.versions.filter(v => v.projectId === p.id).sort((a,b) => b.date > a.date ? 1 : -1)[0];\n    const active = state.selectedProject === p.id ? 'active' : '';\n    return `<div class=\"project-item ${active}\" onclick=\"selectProject('${p.id}')\">\n      <div class=\"project-dot\" style=\"background:${p.color}\"></div>\n      <div class=\"project-info\">\n        <div class=\"project-name\">${p.name}</div>\n        <div class=\"project-meta\">${vCount}개 버전${latest ? ' · ' + formatDate(latest.date) : ''}</div>\n      </div>\n    </div>`;\n  }).join('');\n}\n\n// ─── SELECT PROJECT ──────────────────────────────────────────\nfunction selectProject(id) {\n  state.selectedProject = id;\n  state.currentView = 'projects';\n  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));\n  document.getElementById('nav-projects').classList.add('active');\n  renderSidebar();\n  renderMain();\n}\n\n// ─── RENDER MAIN ─────────────────────────────────────────────\nfunction renderMain() {\n  document.getElementById('empty-state').style.display = 'none';\n  document.getElementById('project-detail').style.display = 'none';\n  document.getElementById('all-versions').style.display = 'none';\n\n  if (state.currentView === 'all') {\n    renderAllVersions();\n    return;\n  }\n\n  if (!state.selectedProject) {\n    document.getElementById('empty-state').style.display = 'flex';\n    return;\n  }\n\n  renderProjectDetail();\n}\n\n// ─── PROJECT DETAIL ──────────────────────────────────────────\nfunction renderProjectDetail() {\n  const p = state.projects.find(p => p.id === state.selectedProject);\n  if (!p) return;\n\n  const versions = state.versions\n    .filter(v => v.projectId === p.id)\n    .sort((a,b) => b.date > a.date ? 1 : -1);\n\n  const detail = document.getElementById('project-detail');\n  detail.style.display = 'block';\n\n  const tagCounts = {};\n  versions.forEach(v => (v.tags||[]).forEach(t => tagCounts[t] = (tagCounts[t]||0)+1));\n\n  detail.innerHTML = `\n    <div class=\"project-header\">\n      <div class=\"project-title-area\">\n        <div class=\"project-tag\">PROJECT · ${p.id.toUpperCase()}</div>\n        <div class=\"project-title\" style=\"color:${p.color}\">${p.name}</div>\n        ${p.desc ? `<div class=\"project-desc\">${p.desc}</div>` : ''}\n      </div>\n      <div style=\"display:flex;gap:8px;align-items:flex-start;flex-shrink:0;\">\n        <button class=\"btn btn-secondary\" onclick=\"openProjectModal('${p.id}')\">편집</button>\n        <button class=\"btn btn-danger\" onclick=\"deleteProject('${p.id}')\">삭제</button>\n      </div>\n    </div>\n\n    <div class=\"stats-row\">\n      <div class=\"stat-card\">\n        <div class=\"stat-label\">총 버전</div>\n        <div class=\"stat-value\"><span>${versions.length}</span></div>\n      </div>\n      <div class=\"stat-card\">\n        <div class=\"stat-label\">최신 버전</div>\n        <div class=\"stat-value\" style=\"font-size:16px;\">${versions[0]?.version || '—'}</div>\n      </div>\n      <div class=\"stat-card\">\n        <div class=\"stat-label\">마지막 업데이트</div>\n        <div class=\"stat-value\" style=\"font-size:14px;\">${versions[0] ? formatDate(versions[0].date) : '—'}</div>\n      </div>\n      <div class=\"stat-card\">\n        <div class=\"stat-label\">버그 수정</div>\n        <div class=\"stat-value\"><span>${tagCounts['fix']||0}</span></div>\n      </div>\n    </div>\n\n    <div class=\"section-header\">\n      <span class=\"section-label\">Version History</span>\n      <button class=\"btn btn-primary\" onclick=\"openVersionModal('${p.id}')\">+ 버전 추가</button>\n    </div>\n\n    <div class=\"version-timeline\" id=\"version-list\">\n      ${versions.length === 0\n        ? `<div style=\"color:var(--text3);font-family:'DM Mono',monospace;font-size:12px;padding:20px 0;\">아직 버전이 없어요. 첫 버전을 추가해보세요!</div>`\n        : versions.map(v => renderVersionCard(v)).join('')\n      }\n    </div>\n  `;\n}\n\n// ─── VERSION CARD ────────────────────────────────────────────\nfunction renderVersionCard(v) {\n  const tagHtml = (v.tags||[]).map(t => {\n    const labels = { fix:'🔧 fix', feat:'✨ feat', update:'🔄 update', init:'🌱 init' };\n    return `<span class=\"v-tag tag-${t}\">${labels[t]||t}</span>`;\n  }).join('');\n\n  const hasDrive = v.drive && v.drive.trim();\n  const hasError = v.error && v.error.trim();\n\n  return `<div class=\"version-card\" id=\"vc-${v.id}\">\n    <div class=\"version-card-head\" onclick=\"toggleVersion('${v.id}')\">\n      <div class=\"v-badge\">${v.version}</div>\n      <div class=\"v-summary\">\n        <div class=\"v-title\">${v.title||'(제목 없음)'}</div>\n        <div class=\"v-date\">${formatDate(v.date)}</div>\n      </div>\n      <div class=\"v-tags\">${tagHtml}</div>\n      <div class=\"v-chevron\">▾</div>\n    </div>\n    <div class=\"version-card-body\">\n      ${v.changes ? `<div class=\"v-section\"><div class=\"v-section-label\">변경 내용</div><div class=\"v-content\">${v.changes}</div></div>` : ''}\n      ${v.reason ? `<div class=\"v-section\"><div class=\"v-section-label\">변경 이유</div><div class=\"v-content\">${v.reason}</div></div>` : ''}\n      ${hasError ? `<div class=\"v-section\"><div class=\"v-section-label\" style=\"color:var(--red);\">발생한 오류</div><div class=\"v-content\" style=\"color:var(--red);opacity:.8;\">${v.error}</div></div>` : ''}\n      ${v.fileName ? `<div class=\"v-section\"><div class=\"v-section-label\">첨부 파일</div>\n        <div class=\"file-btns\">\n          <button class=\"btn-file preview\" onclick=\"previewFile('${v.id}')\">🔍 미리보기</button>\n          <button class=\"btn-file download\" onclick=\"downloadFile('${v.id}')\">⬇ 다운로드</button>\n          <span style=\"font-family:'DM Mono',monospace;font-size:11px;color:var(--text3);align-self:center;\">${v.fileName}</span>\n        </div></div>` : ''}\n      <div class=\"v-actions\">\n        <button class=\"btn btn-secondary\" onclick=\"openVersionModal('${v.projectId}','${v.id}')\">편집</button>\n        <button class=\"btn btn-danger\" onclick=\"deleteVersion('${v.id}')\">삭제</button>\n      </div>\n    </div>\n  </div>`;\n}\n\nfunction toggleVersion(id) {\n  document.getElementById('vc-' + id)?.classList.toggle('expanded');\n}\n\n// ─── ALL VERSIONS ────────────────────────────────────────────\nfunction renderAllVersions() {\n  const allV = [...state.versions].sort((a,b) => b.date > a.date ? 1 : -1);\n  const el = document.getElementById('all-versions');\n  el.style.display = 'block';\n\n  el.innerHTML = `\n    <div style=\"margin-bottom:24px;\">\n      <div style=\"font-family:'DM Mono',monospace;font-size:11px;color:var(--text3);margin-bottom:6px;\">ALL VERSIONS</div>\n      <div style=\"font-family:'Instrument Serif',serif;font-size:28px;font-style:italic;\">전체 업데이트 로그</div>\n    </div>\n    ${allV.length === 0\n      ? `<div style=\"color:var(--text3);font-family:'DM Mono',monospace;font-size:12px;\">아직 버전이 없어요!</div>`\n      : allV.map(v => {\n          const p = state.projects.find(p => p.id === v.projectId);\n          return `<div style=\"margin-bottom:2px;\">\n            <div style=\"font-family:'DM Mono',monospace;font-size:10px;color:var(--text3);padding:8px 0 4px;\">${p?.name || '?'}</div>\n            ${renderVersionCard(v)}\n          </div>`;\n        }).join('')\n    }\n  `;\n}\n\n// ─── PROJECT MODAL ───────────────────────────────────────────\nfunction openProjectModal(id) {\n  state.editingProjectId = id || null;\n  state.selectedColor = '#c8f04e';\n\n  if (id) {\n    const p = state.projects.find(p => p.id === id);\n    document.getElementById('project-modal-title').textContent = '프로젝트 편집';\n    document.getElementById('pm-id').value = p.id;\n    document.getElementById('pm-name').value = p.name;\n    document.getElementById('pm-desc').value = p.desc || '';\n    state.selectedColor = p.color;\n  } else {\n    document.getElementById('project-modal-title').textContent = '새 프로젝트';\n    document.getElementById('pm-id').value = '';\n    document.getElementById('pm-name').value = '';\n    document.getElementById('pm-desc').value = '';\n  }\n  updateColorOpts();\n  openModal('project-modal');\n}\n\nfunction selectColor(c) {\n  state.selectedColor = c;\n  updateColorOpts();\n}\nfunction updateColorOpts() {\n  document.querySelectorAll('.color-opt').forEach(el => {\n    el.classList.toggle('selected', el.dataset.color === state.selectedColor);\n  });\n}\n\nfunction saveProject() {\n  const name = document.getElementById('pm-name').value.trim();\n  if (!name) { toast('프로젝트 이름을 입력해주세요!'); return; }\n\n  const id = document.getElementById('pm-id').value;\n  if (id) {\n    const p = state.projects.find(p => p.id === id);\n    p.name = name;\n    p.desc = document.getElementById('pm-desc').value.trim();\n    p.color = state.selectedColor;\n  } else {\n    state.projects.push({ id: uid(), name, desc: document.getElementById('pm-desc').value.trim(), color: state.selectedColor });\n  }\n  save(); closeModal('project-modal'); renderSidebar();\n  if (id && state.selectedProject === id) renderMain();\n  toast('저장됐어요 ✓', 'success');\n}\n\nfunction deleteProject(id) {\n  if (!confirm('이 프로젝트와 모든 버전을 삭제할까요?')) return;\n  state.projects = state.projects.filter(p => p.id !== id);\n  state.versions = state.versions.filter(v => v.projectId !== id);\n  if (state.selectedProject === id) state.selectedProject = null;\n  save(); renderSidebar(); renderMain();\n  toast('삭제됐어요');\n}\n\n// ─── VERSION MODAL ───────────────────────────────────────────\nfunction openVersionModal(projectId, versionId) {\n  state.selectedTags = [];\n  document.querySelectorAll('.tag-opt').forEach(el => el.className = 'tag-opt');\n\n  if (versionId) {\n    const v = state.versions.find(v => v.id === versionId);\n    document.getElementById('version-modal-title').textContent = '버전 편집';\n    document.getElementById('vm-id').value = v.id;\n    document.getElementById('vm-project-id').value = v.projectId;\n    document.getElementById('vm-version').value = v.version;\n    document.getElementById('vm-date').value = v.date;\n    document.getElementById('vm-title').value = v.title || '';\n    document.getElementById('vm-changes').value = v.changes || '';\n    document.getElementById('vm-reason').value = v.reason || '';\n    document.getElementById('vm-error').value = v.error || '';\n    document.getElementById('vm-file-name').value = v.fileName || '';\n    document.getElementById('vm-file-content').value = v.fileContent || '';\n    if (v.fileName) {\n      const area = document.getElementById('file-upload-area');\n      document.getElementById('file-upload-label').textContent = '✓ ' + v.fileName;\n      area.classList.add('has-file');\n    } else resetFileUpload();\n    state.selectedTags = v.tags || [];\n    state.selectedTags.forEach(t => {\n      const el = document.querySelector(`.tag-opt[data-tag=\"${t}\"]`);\n      if (el) el.className = `tag-opt selected-${t}`;\n    });\n  } else {\n    document.getElementById('version-modal-title').textContent = '버전 추가';\n    document.getElementById('vm-id').value = '';\n    document.getElementById('vm-project-id').value = projectId;\n    document.getElementById('vm-version').value = '';\n    document.getElementById('vm-date').value = today();\n    document.getElementById('vm-title').value = '';\n    document.getElementById('vm-changes').value = '';\n    document.getElementById('vm-reason').value = '';\n    document.getElementById('vm-error').value = '';\n    document.getElementById('vm-file-name').value = '';\n    document.getElementById('vm-file-content').value = '';\n    resetFileUpload();\n  }\n  openModal('version-modal');\n}\n\nfunction toggleTag(el) {\n  const tag = el.dataset.tag;\n  if (state.selectedTags.includes(tag)) {\n    state.selectedTags = state.selectedTags.filter(t => t !== tag);\n    el.className = 'tag-opt';\n  } else {\n    state.selectedTags.push(tag);\n    el.className = `tag-opt selected-${tag}`;\n  }\n}\n\nfunction saveVersion() {\n  const version = document.getElementById('vm-version').value.trim();\n  const title = document.getElementById('vm-title').value.trim();\n  if (!version) { toast('버전 번호를 입력해주세요!'); return; }\n  if (!title) { toast('제목을 입력해주세요!'); return; }\n\n  const id = document.getElementById('vm-id').value;\n  const data = {\n    projectId: document.getElementById('vm-project-id').value,\n    version,\n    date: document.getElementById('vm-date').value || today(),\n    title,\n    tags: [...state.selectedTags],\n    changes: document.getElementById('vm-changes').value.trim(),\n    reason: document.getElementById('vm-reason').value.trim(),\n    error: document.getElementById('vm-error').value.trim(),\n    fileName: document.getElementById('vm-file-name').value || null,\n    fileContent: document.getElementById('vm-file-content').value || null,\n  };\n\n  if (id) {\n    const idx = state.versions.findIndex(v => v.id === id);\n    state.versions[idx] = { ...state.versions[idx], ...data };\n  } else {\n    state.versions.push({ id: uid(), ...data });\n  }\n\n  save(); closeModal('version-modal'); renderMain();\n  toast('버전이 저장됐어요 ✓', 'success');\n}\n\nfunction deleteVersion(id) {\n  if (!confirm('이 버전 기록을 삭제할까요?')) return;\n  state.versions = state.versions.filter(v => v.id !== id);\n  save(); renderMain();\n  toast('삭제됐어요');\n}\n\n// ─── MODAL HELPERS ───────────────────────────────────────────\nfunction openModal(id) { document.getElementById(id).classList.add('open'); }\nfunction closeModal(id) { document.getElementById(id).classList.remove('open'); }\n\ndocument.querySelectorAll('.modal-overlay').forEach(el => {\n  el.addEventListener('click', e => { if (e.target === el) closeModal(el.id); });\n});\n\n// ─── FILE HANDLING ───────────────────────────────────────────\nfunction handleFileUpload(input) {\n  const file = input.files[0];\n  if (!file) return;\n  const reader = new FileReader();\n  reader.onload = e => {\n    document.getElementById('vm-file-name').value = file.name;\n    document.getElementById('vm-file-content').value = e.target.result;\n    const area = document.getElementById('file-upload-area');\n    document.getElementById('file-upload-label').textContent = '✓ ' + file.name;\n    area.classList.add('has-file');\n    toast('파일 로드됐어요 ✓', 'success');\n  };\n  reader.readAsText(file);\n}\n\nfunction resetFileUpload() {\n  const area = document.getElementById('file-upload-area');\n  document.getElementById('file-upload-label').textContent = '📎 클릭해서 HTML 파일 선택';\n  area.classList.remove('has-file');\n  document.getElementById('vm-file-input').value = '';\n}\n\nfunction previewFile(versionId) {\n  const v = state.versions.find(v => v.id === versionId);\n  if (!v?.fileContent) return;\n  const blob = new Blob([v.fileContent], { type: 'text/html' });\n  const url = URL.createObjectURL(blob);\n  window.open(url, '_blank');\n}\n\nfunction downloadFile(versionId) {\n  const v = state.versions.find(v => v.id === versionId);\n  if (!v?.fileContent) return;\n  const blob = new Blob([v.fileContent], { type: 'text/html' });\n  const a = document.createElement('a');\n  a.href = URL.createObjectURL(blob);\n  a.download = v.fileName || 'file.html';\n  a.click();\n  toast('다운로드 시작! ⬇', 'success');\n}\n\n// ─── SETTINGS MODAL ──────────────────────────────────────────\nfunction openSettingsModal() {\n  const c = getGHConfig();\n  document.getElementById('s-owner').value = c.owner;\n  document.getElementById('s-repo').value = c.repo;\n  document.getElementById('s-token').value = c.token;\n  openModal('settings-modal');\n}\n\nasync function saveGHConfig() {\n  const owner = document.getElementById('s-owner').value.trim();\n  const repo  = document.getElementById('s-repo').value.trim();\n  const token = document.getElementById('s-token').value.trim();\n  if (!owner || !repo || !token) { toast('모두 입력해주세요!'); return; }\n  localStorage.setItem('gh-owner', owner);\n  localStorage.setItem('gh-repo',  repo);\n  localStorage.setItem('gh-token', token);\n  _sha = null;\n  closeModal('settings-modal');\n  toast('GitHub 연동 시도 중...', '');\n  await load();\n  renderSidebar();\n  renderMain();\n  if (isGHConfigured()) toast('GitHub 연동 완료! ✓', 'success');\n}\n\nfunction clearGHConfig() {\n  if (!confirm('GitHub 연동을 해제할까요? (로컬 데이터는 유지됩니다)')) return;\n  localStorage.removeItem('gh-owner');\n  localStorage.removeItem('gh-repo');\n  localStorage.removeItem('gh-token');\n  _sha = null;\n  setSyncStatus('local');\n  closeModal('settings-modal');\n  toast('연동 해제됐어요');\n}\n\n// ─── INIT ────────────────────────────────────────────────────\nload().then(() => {\n  renderSidebar();\n  renderMain();\n});\n</script>\n</body>\n</html>\n"
    }
  ]
}